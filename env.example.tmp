# =============================================================================
# Application
# =============================================================================
DEBUG=0
SECRET_KEY=your-secret-key-here

# =============================================================================
# Service URLs
# =============================================================================
EMBEDDING_URL=
LLM_URL=
SYSTEM_AGENT_URL=
PYAGENT_URL=

# =============================================================================
# Model Loading
# Which model this container loads via llama-cpp-python ("instruct" or "reasoning").
# Must match a key in config.model_paths.
# =============================================================================
ACTIVE_MODEL=instruct

# =============================================================================
# Database (PostgreSQL) — only used when POSTGRES_READY=1
# =============================================================================
POSTGRES_READY=0
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=octagent
SQL_USER=postgres
SQL_PASSWORD=your-db-password-here
SQL_HOST=localhost
SQL_PORT=5432

# =============================================================================
# PostgreSQL Backup
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# CUDA / GPU (2x GPUs)
# =============================================================================
CUDA_VISIBLE_DEVICES=0,1

# Split model layers across GPUs (ratio per GPU, must sum to ~1.0)
# Equal split for 2 identical GPUs; adjust if VRAM differs (e.g. 0.6,0.4)
TENSOR_SPLIT=0.5,0.5

# Primary GPU for small tensors and scratch buffers (0-indexed)
MAIN_GPU=0

# =============================================================================
# Inference Performance
# =============================================================================
# GPU layers: -1 = offload ALL layers to GPU (fastest)
N_GPU_LAYERS=-1

# Prompt processing batch size (higher = faster prompt ingestion, more VRAM)
N_BATCH=2048

# CPU threads for inference (0 = auto-detect, uses 90% of cores)
N_THREADS=0

# Memory-map model file (faster loading, less RAM duplication)
USE_MMAP=1

# Lock model in RAM (prevents swapping to disk under memory pressure)
USE_MLOCK=1

# Flash attention (faster decoding, lower VRAM usage)
FLASH_ATTN=1

# NVCC_THREADS=4
# TORCH_CUDA_ARCH_LIST=8.6
