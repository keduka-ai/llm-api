# =============================================================================
# LLM API Deploy — Environment Configuration
# Copy this file to .env and adjust values as needed.
# =============================================================================

# --- Mode ---
# Which model type to serve: "instruct" or "reasoning"
RUNPOD_MODE=instruct

# --- Model files ---
# Directory where GGUF model files are stored
MODELS_DIR=/models
# Model filenames (must exist in MODELS_DIR)
INSTRUCT_MODEL=Qwen3.5-4B-Q4_1.gguf
REASONING_MODEL=Phi-4-mini-reasoning-UD-Q8_K_XL.gguf

# --- Generation defaults ---
# Max tokens a single request can generate (upper safety cap)
MAX_GENERATION_TOKENS=75000
# Default max_tokens when caller omits the parameter
DEFAULT_MAX_TOKENS=4096
# Maximum number of messages allowed per request
MAX_MESSAGES=256

# --- GPU configuration ---
# Number of layers to offload to GPU (-1 = all layers)
N_GPU_LAYERS=-1
# Batch size for prompt processing
N_BATCH=512
# Micro-batch size (per-model override via MODEL_CONFIG takes precedence)
# N_UBATCH=512
# Enable flash attention (1=on, 0=off)
FLASH_ATTN=1
# Use memory-mapped model loading (1=on, 0=off)
USE_MMAP=1
# Lock model in RAM to prevent swapping (1=on, 0=off)
USE_MLOCK=1
# Primary GPU index for single-GPU inference
MAIN_GPU=0
# Multi-GPU tensor split — comma-separated floats (e.g. "0.5,0.5")
# TENSOR_SPLIT=

# --- Context window ---
# Override per-model context window (leave unset to use MODEL_CONFIG defaults)
# N_CTX=20000
